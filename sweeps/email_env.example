RESEND_API_KEY=re_xxxxxxxxx
DIGEST_FROM_EMAIL=digest@example.com
DIGEST_FROM_NAME=AI Sweep
DIGEST_VISIBLE_TO_EMAIL=digest@example.com
DIGEST_TO_EMAILS=bmoore7789@gmail.com,moonhodler@gmail.com
DIGEST_EMAIL_ENABLED=true
DIGEST_WEEKLY_EMAIL_ENABLED=false
SWEEP_AI_SUMMARY_ENABLED=false
SWEEP_AI_SUMMARY_MODEL=qwen2.5:14b
SWEEP_AI_SUMMARY_URL=http://127.0.0.1:11434/api/generate
# Local LLM synthesis (sweeps/llm_synthesize.py, called from run_workflow.py).
# Leave LLM_SYNTHESIS_ENDPOINT blank to disable. Default model is mistral-small3.1:24b.
LLM_SYNTHESIS_ENDPOINT=http://192.168.1.198:11434/v1/chat/completions
LLM_SYNTHESIS_MODEL=mistral-small3.1:24b
X_EMAIL_IMAP_HOST=imap.example.com
X_EMAIL_IMAP_PORT=993
X_EMAIL_IMAP_USERNAME=x-notify@example.com
X_EMAIL_IMAP_PASSWORD=app-password-or-mailbox-password
SWEEP_OPENRSS_FALLBACK_ENABLED=
X_EMAIL_IMAP_MAILBOX=INBOX
X_EMAIL_FROM_FILTER=x.com,twitter.com
